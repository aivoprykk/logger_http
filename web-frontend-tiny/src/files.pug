extends layout.pug

block content
  main  
    .container
      article.card.files
        header.card-header
          .flexrow
            h2 Files
            .left.selection.hide(hidden)
              button.outline.dl Download selected
              button.outline.rm Delete selected
              button.outline.ar Archive selected
            .right.upload-file
              label.upload-file-select
                span.file-text Upload file
                input(type="file")
              button.outline.upload-submit.hide Upload
          .flexrow.info
        .card-body
          img(src="assets/logo.svg")